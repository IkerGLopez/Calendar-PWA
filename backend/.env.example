# Archivo de ejemplo para despliegue y desarrollo del Backend

# Puerto donde correrá el servidor Node.js
PORT=3001

# Claves VAPID para Web Push Notifications (Generar con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=tu_clave_publica_aqui
VAPID_PRIVATE_KEY=tu_clave_privada_aqui

# URL del frontend para habilitar CORS (Ej: https://tu-frontend.vercel.app)
# FRONTEND_URL=http://localhost:5173
FRONTEND_URL=*
